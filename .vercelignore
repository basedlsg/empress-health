# Vercel serverless deploy — keep the bundle small.
# .vercelignore uses .gitignore syntax. A leading slash anchors to the
# repo root; without it the pattern matches at any depth, which would
# wrongly exclude pages/<slug>.html etc. So every legacy *.html entry
# here is anchored with /.

# === Bulk: never deploy ===
node_modules
.git
.github
.cursor

# === Build artifacts (Vercel rebuilds via buildCommand) ===
prds/dist

# === Legacy HTML files at repo root ===
# DO NOT ignore these — scripts/copy-legacy-html-to-public.mjs reads them
# at build time and stages them into public/ so Vercel serves them at
# canonical URLs (/signup, /askempress, /our-program, etc.). Excluding them
# here produces a working build that returns 404 on every static page.
# The only file that's safe to skip is the local-only test page.
/empresshealth.ai-test.html

# === Mockpages — internal scratch ===
/mockpages

# === Public assets — keep only essentials for demo ===
# Redesigned pages use <Placeholder> components for photography, so we can
# drop nearly all of public/. Keep EmpressHealthlogo + blogs.json.
/public/blogs/blogsymptoms_files
/public/blogsv2
/public/blogs/**/*.zip
/public/coverphotos
/public/titlephotos
/public/report-heroes
/public/banners
/public/affirmations
/public/affirmations*
/public/headshots
/public/Canva*
/public/events
/public/features
/public/doctors
/public/*.zip
/public/*.mp4
/public/*.mov
/public/teahands.png
