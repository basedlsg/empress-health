# Vercel serverless deploy — keep the bundle small.
# .vercelignore uses .gitignore syntax. A leading slash anchors to the
# repo root; without it the pattern matches at any depth, which would
# wrongly exclude pages/<slug>.html etc. So every legacy *.html entry
# here is anchored with /.

# === Bulk: never deploy ===
node_modules
.git
.github
.cursor

# === Build artifacts (Vercel rebuilds via buildCommand) ===
prds/dist

# === Legacy HTML files at repo root (cutover serves from pages/* now) ===
# Anchored to root so /pages/<slug>.html is NOT matched.
/betacomingsoon.html
/betaversion.html
/bundlesandkits.html
/community.html
/communitystories.html
/contact.html
/dailyaffirmations.html
/dom.html
/ebookguides.html
/events.html
/expertblogs.html
/expertguidance.html
/faq.html
/founderstory.html
/haircare.html
/howitworks.html
/index.html
/login.html
/market.html
/membershipoptions.html
/membershipsurvey.html
/menopausemonth.html
/ourstory.html
/privacypolicy.html
/selfcaretools.html
/signup.html
/skincare.html
/supplements.html
/symptomsupport.html
/team.html
/wellnesshub.html
/whyempresshealth.html
/askempress.html
/cookies.html
/accessibility.html
/empresshealth.ai-test.html

