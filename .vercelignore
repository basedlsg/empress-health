# Vercel serverless deploy — keep the bundle small.
# .vercelignore uses .gitignore syntax. A leading slash anchors to the
# repo root; without it the pattern matches at any depth, which would
# wrongly exclude pages/<slug>.html etc. So every legacy *.html entry
# here is anchored with /.

# === Bulk: never deploy ===
node_modules
.git
.github
.cursor

# === Build artifacts (Vercel rebuilds via buildCommand) ===
prds/dist

# === Legacy HTML files at repo root ===
# DO NOT ignore these — scripts/copy-legacy-html-to-public.mjs reads them
# at build time and stages them into public/ so Vercel serves them at
# canonical URLs (/signup, /askempress, /our-program, etc.). Excluding them
# here produces a working build that returns 404 on every static page.
# The only file that's safe to skip is the local-only test page.
/empresshealth.ai-test.html

# === Mockpages — internal scratch ===
/mockpages

# === Public assets ===
# Every folder below is referenced by the live pages (homepage uses
# features/, doctors/, affirmations/, headshots/; other pages use
# titlephotos/, coverphotos/, banners/, events/, report-heroes/).
# Previously stripping them produced ~40 404s across the homepage alone.
# Only keep ignoring third-party scraped content, archives, and large
# media that's known to be unused.
/public/blogs/blogsymptoms_files
/public/blogsv2
/public/blogs/**/*.zip
/public/Canva*
/public/*.zip
/public/*.mp4
/public/*.mov
# Single-file outliers (each 5-24MB, not referenced from any page that's
# part of the user-facing flow). Add new entries here as you spot them.
/public/coverphotos/whatisempress.png
/public/expert4.png

# === Heavy reference docs not needed at runtime ===
/Health Assessment Report (1).pdf
/Empress_Full_Assessment_Questions.docx
/Empress_Health_FAQ.pdf
/assessment_questions.csv

# === Site-bots (Playwright) and design canvas tooling ===
/site-bots
/artifacts
/email_outbox.log
/design-references/screenshots

# === OS / misc ===
.DS_Store
*.log
/status.txt
/build_out*.txt
