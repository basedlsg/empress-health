{
  "version": 2,
  "framework": null,
  "buildCommand": "npm install && npm run build:assessment && node scripts/copy-legacy-html-to-public.mjs",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "excludeFiles": "{public/**,Hero Image/**,EmpressHealth logo - RGB - Modified/**,design-references/**,prds/dist/**,empress-free-trial-assessment.pdf,Health Assessment Report (1).pdf,pages/**,site-bots/**,scripts/**,docs/**,*.docx,*.csv,artifacts/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/qa", "destination": "/api/index" },
    { "source": "/free-assessment", "destination": "/free-assessment.html" },
    { "source": "/health-assessment", "destination": "/api/index" },
    { "source": "/r", "destination": "/pages/home" },
    { "source": "/r/:slug", "destination": "/pages/:slug" },
    { "source": "/public/(.*)", "destination": "/$1" }
  ],
  "env": {
    "NODE_ENV": "development",
    "MOCK_LLM": "0",
    "ALLOW_UNGROUNDED_FASTAPI": "0",
    "VERCEL_DEMO": "1",
    "SESSION_SECRET": "vercel-demo-only-not-a-real-secret-fffffffffffffffff"
  }
}
