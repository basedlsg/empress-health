  <meta name="description" content="Empress Health.ai Privacy & Data Protection Policy (Non-HIPAA). Learn how we collect, use, protect, and share your information." />
  <style>
    :root {
      --ink: #1a1520;
      --muted: #5c5668;
      --primary: #3F1449;
      --accent: #D8A738;
      --border: rgba(0,0,0,.1);
      --bg: #ffffff;
      --bg-soft: #f8f7f5;
      --header-h: 100px;
      --radius-lg: 16px;
      --shadow: 0 8px 24px rgba(0,0,0,.06);
    }
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      padding-top: var(--header-h);
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 17px;
      line-height: 1.75;
      color: var(--ink);
      background: var(--bg);
    }
    a { color: var(--primary); text-decoration: none; }
    a:hover { text-decoration: underline; }
    a:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    .skip-link {
      position: absolute;
      top: -100px;
      left: 24px;
      padding: 12px 16px;
      background: var(--primary);
      color: #fff;
      font-weight: 600;
      z-index: 9999;
      transition: top 0.2s;
    }
    .skip-link:focus { top: 12px; }

    @media (max-width: 820px) { :root { --header-h: 72px; } }

    /* Header / nav (full menu) */
    #site-header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 9999;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      transition: box-shadow 0.2s ease;
    }
    #site-header.is-stuck { box-shadow: 0 4px 20px rgba(0,0,0,.08); }
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0.75rem 24px;
    }
    @media (min-width: 821px) {
      .nav { justify-content: center; gap: 32px; padding: 0.5rem 64px; }
    }
    .brand { display: flex; align-items: center; gap: 0.6rem; flex-shrink: 0; }
    .brand-logo { height: clamp(52px, 6vw, 70px); display: block; }
    .main-nav { display: none; align-items: center; gap: 14px; }
    .menu-item { position: relative; }
    .menu-trigger {
      background: transparent; border: 0; cursor: pointer; font-weight: 600;
      font-size: 0.9375rem; color: var(--ink); padding: 0.5rem 0.4rem;
      border-radius: 8px; white-space: nowrap; transition: color 0.15s;
    }
    .menu-trigger:hover { color: var(--primary); }
    .menu-trigger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .menu-item[data-open="1"] .menu-trigger { color: var(--primary); }
    .menu-panel {
      position: absolute; top: calc(100% + 10px); left: 0; z-index: 1001;
      width: min(480px, 85vw); background: var(--bg); border: 1px solid var(--border);
      border-radius: var(--radius-lg); box-shadow: var(--shadow);
      padding: 16px; display: none;
    }
    .menu-item:hover .menu-panel, .menu-item:focus-within .menu-panel, .menu-item[data-open="1"] .menu-panel { display: block; }
    .menu-item:nth-child(n+5) .menu-panel { left: auto; right: 0; }
    .menu-item:nth-child(3) .menu-panel, .menu-item:nth-child(4) .menu-panel { left: 50%; transform: translateX(-50%); right: auto; }
    .menu-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .menu-section h5 { margin: 0 0 8px; font-weight: 700; font-size: 0.875rem; color: var(--primary); font-family: system-ui, sans-serif; }
    .menu-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
    .menu-link {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 10px; border: 1px solid var(--border); border-radius: 8px;
      background: var(--bg); transition: all 0.15s; font-size: 0.875rem;
    }
    .menu-link:hover { border-color: var(--accent); box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .menu-link:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
    .menu-desc { font-size: 0.75rem; color: var(--muted); }
    .burger {
      width: 52px; height: 52px; border-radius: 12px; border: 1px solid var(--border);
      background: var(--bg); display: grid; place-items: center; cursor: pointer;
      font-size: 28px; color: var(--ink);
    }
    .burger:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    #drawer {
      display: none; position: fixed; top: var(--header-h); left: 0; right: 0;
      background: var(--bg); border-top: 1px solid var(--border);
      box-shadow: 0 8px 24px rgba(0,0,0,.1); z-index: 9998;
      max-height: calc(100vh - var(--header-h)); overflow-y: auto;
    }
    #drawer.open { display: block; }
    .drawer { padding: 20px 24px; }
    .home-link { display: block; padding: 14px 0; font-weight: 700; font-size: 1rem; color: var(--primary); border-bottom: 1px solid var(--border); margin-bottom: 8px; }
    .drawer details { border-top: 1px solid var(--border); padding: 8px 0; }
    .drawer summary { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; font-weight: 700; cursor: pointer; list-style: none; }
    .drawer summary::-webkit-details-marker { display: none; }
    .drawer summary::after { content: '›'; font-size: 20px; transition: transform 0.2s; }
    .drawer details[open] summary::after { transform: rotate(90deg); }
    .drawer ul { list-style: none; padding: 8px 0 8px 16px; margin: 0; display: grid; gap: 10px; }
    .drawer a { color: var(--muted); font-size: 0.9375rem; display: block; padding: 6px 0; }
    .drawer a:hover { color: var(--primary); }
    @media (min-width: 821px) { .main-nav { display: flex; } .burger { display: none; } #drawer { display: none !important; } }

