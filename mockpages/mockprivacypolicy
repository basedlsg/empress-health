        padding-left: 20px;
      }
      .toc-desktop ul { list-style: none; margin: 0; padding: 0; }
      .toc-desktop li { margin: 10px 0; }
      .toc-desktop a {
        display: block;
        padding: 6px 0;
        font-size: 15px;
        color: var(--muted);
      }
      .toc-desktop a:hover { color: var(--primary); }
      .toc-desktop a.active { font-weight: 600; color: var(--primary); }
    }

    main { outline: none; }
    article { max-width: 72ch; }
    .policy-section {
      padding: 28px 0;
      border-bottom: 1px solid var(--border);
    }
    .policy-section:last-of-type { border-bottom: none; }
    .policy-section h2 {
      margin: 0 0 16px;
      font-size: 24px;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.25;
    }
    .policy-section p {
      margin: 0 0 12px;
      font-size: 17px;
      line-height: 1.75;
    }
    .policy-section ul {
      margin: 12px 0;
      padding-left: 1.5em;
    }
    .policy-section li {
      margin: 8px 0;
      font-size: 17px;
      line-height: 1.7;
    }
    .contact-email, .policy-section a[href^="mailto:"] {
      font-family: ui-monospace, monospace;
      background: var(--bg-soft);
      padding: 2px 8px;
      border-radius: 4px;
    }

    footer.site-footer {
      margin-top: 48px;
      padding: 24px;
      text-align: center;
      font-size: 14px;
      color: var(--muted);
      border-top: 1px solid var(--border);
    }
  </style>
