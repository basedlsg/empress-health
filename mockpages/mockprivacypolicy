      margin: 0 auto;
      padding: 0 24px 48px;
    }
    @media (min-width: 1024px) {
      .layout-wrap {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 48px;
        max-width: 1200px;
        padding: 0 48px 64px;
      }
      .policy-content { min-width: 0; }
    }

    .toc-mobile {
      margin-bottom: 24px;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }
    .toc-mobile summary {
      padding: 16px 20px;
      font-weight: 600;
      cursor: pointer;
      list-style: none;
      min-height: 44px;
      display: flex;
      align-items: center;
    }
    .toc-mobile summary::-webkit-details-marker { display: none; }
    .toc-mobile[open] summary { border-bottom: 1px solid var(--border); }
    .toc-mobile ul {
      margin: 0;
      padding: 12px 20px 16px;
      list-style: none;
    }
    .toc-mobile li { margin: 8px 0; }
    .toc-mobile a {
      display: block;
      padding: 10px 0;
      min-height: 44px;
      display: flex;
      align-items: center;
      color: var(--ink);
    }
    .toc-mobile a:hover { color: var(--primary); }
    .toc-mobile a.active { font-weight: 600; color: var(--primary); }
    @media (min-width: 1024px) {
      .toc-mobile { display: none; }
    }

    .toc-desktop {
      display: none;
    }
    @media (min-width: 1024px) {
      .toc-desktop {
        display: block;
        position: sticky;
        top: 24px;
        align-self: start;
      }
      .toc-desktop nav {
