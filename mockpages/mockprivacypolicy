  <script>
  (function() {
    document.getElementById('last-updated').textContent = new Date().toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' });

    /* Menu: desktop dropdowns, burger drawer, sticky header */
    var desktopItems = Array.from(document.querySelectorAll('.main-nav .menu-item'));
    function closeAllMenus() {
      desktopItems.forEach(function(item) {
        item.dataset.open = '0';
        var trigger = item.querySelector('.menu-trigger');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      });
    }
    desktopItems.forEach(function(item) {
      var trigger = item.querySelector('.menu-trigger');
      trigger && trigger.addEventListener('click', function(e) {
        e.preventDefault();
        var isOpen = item.dataset.open === '1';
        closeAllMenus();
        if (!isOpen) { item.dataset.open = '1'; trigger.setAttribute('aria-expanded', 'true'); }
      });
      item.addEventListener('mouseleave', function() {
        item.dataset.open = '0';
        var t = item.querySelector('.menu-trigger');
        if (t) t.setAttribute('aria-expanded', 'false');
      });
    });
    var burger = document.getElementById('burger');
    var drawer = document.getElementById('drawer');
    function toggleDrawer(open) {
      if (!drawer || !burger) return;
      drawer.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    }
    burger && burger.addEventListener('click', function() { toggleDrawer(!drawer.classList.contains('open')); });
    drawer && drawer.addEventListener('click', function(e) { if (e.target.tagName === 'A') toggleDrawer(false); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') toggleDrawer(false); });
    window.matchMedia('(min-width: 821px)').addEventListener('change', function(e) { if (e.matches) toggleDrawer(false); });
    var header = document.getElementById('site-header');
    if (header) window.addEventListener('scroll', function() { header.classList.toggle('is-stuck', window.scrollY > 10); }, { passive: true });

    var sections = document.querySelectorAll('.policy-section');
    var tocMobile = document.querySelectorAll('#toc-list-mobile a');
    var tocDesktop = document.querySelectorAll('#toc-list-desktop a');

    function setActive(index) {
      tocMobile.forEach(function(a, i) {
        a.classList.toggle('active', i === index);
        a.setAttribute('aria-current', i === index ? 'true' : null);
      });
      tocDesktop.forEach(function(a, i) {
        a.classList.toggle('active', i === index);
        a.setAttribute('aria-current', i === index ? 'true' : null);
      });
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var id = entry.target.id;
        var index = Array.prototype.indexOf.call(sections, entry.target);
        if (index >= 0) setActive(index);
      });
    }, { rootMargin: '-20% 0px -60% 0px', threshold: 0 });

    sections.forEach(function(section) { observer.observe(section); });
  })();
  </script>
